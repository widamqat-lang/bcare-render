# Environment Configuration Example
# انسخ هذا الملف إلى .env أو .env.local وعدّل القيم

# API Configuration
# استخدم الـ URL الخاص بـ Backend
# للتطوير المحلي: http://localhost:5000/api
# للإنتاج على Vercel: https://your-api-domain.com/api
# أو اترك فارغاً واستخدم /api (Relative Path) في الإنتاج

VITE_API_BASE_URL=http://localhost:5000/api

# Port للتطوير
VITE_PORT=5173

# Host للـ API (للتطوير المحلي)
VITE_API_HOST=localhost
VITE_API_PORT=5000

# Base Path (للـ Deployment مع subpath)
BASE_PATH=/
