# ═══════════════════════════════════════════════════════════════
# متغيرات البيئة لمشروع BCare على Render
# ═══════════════════════════════════════════════════════════════
# انسخ هذا الملف إلى .env وأضف القيم الفعلية

# ─────────────────────────────────────────────────────────────
# Supabase Configuration (مطلوب)
# ─────────────────────────────────────────────────────────────
# ابحث عن هذه القيم في لوحة تحكم Supabase > Settings > API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here

# ─────────────────────────────────────────────────────────────
# Server Configuration (اختياري)
# ─────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=production

# ─────────────────────────────────────────────────────────────
# Logging (اختياري)
# ─────────────────────────────────────────────────────────────
LOG_LEVEL=info